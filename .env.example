# Copied to .env automatically by `npm run dev` if .env doesn't exist.
# Paste your Supabase values in (Supabase dashboard → Connect shows all of these).
#
# DATABASE_URL = "Transaction pooler" URI (port 6543) + ?pgbouncer=true&connection_limit=1
# DIRECT_URL   = "Session pooler" URI (port 5432, same pooler host).
#                Use the session pooler, NOT the db.*.supabase.co direct host —
#                the direct host is IPv6-only and unreachable from Vercel.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:5432/postgres"

# Any long random string; generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="lolosel-local-demo-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"
