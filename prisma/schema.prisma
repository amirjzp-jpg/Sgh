generator client {
  provider = "prisma-client-js"
}

datasource db {
  // url: Supabase transaction pooler (port 6543) — what the app uses at runtime.
  // directUrl: direct connection (port 5432) — used by `prisma db push`/migrations,
  // which can't run through pgbouncer.
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Kept portable across SQLite/Postgres (no enums or scalar lists):
// - enum-like fields are Strings, validated with Zod at the API boundary
// - Listing.images is a JSON-encoded string array

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  city         String   @default("Vancouver")
  avatarUrl    String?
  rating       Float?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  listings            Listing[]
  offers              Offer[]
  buyerConversations  Conversation[] @relation("BuyerConversations")
  sellerConversations Conversation[] @relation("SellerConversations")
  messages            Message[]
  buyerOrders         Order[]        @relation("BuyerOrders")
  sellerOrders        Order[]        @relation("SellerOrders")
  walletTxns          WalletTxn[]
  reviewsGiven        Review[]       @relation("ReviewsGiven")
  reviewsReceived     Review[]       @relation("ReviewsReceived")
  reportsMade         Report[]       @relation("ReportsMade")
  reportsAgainst      Report[]       @relation("ReportsAgainst")
  blocksMade          Block[]        @relation("BlocksMade")
  blocksAgainst       Block[]        @relation("BlocksAgainst")
}

model Listing {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  title       String
  description String
  priceCents  Int
  category    String
  condition   String
  images      String // JSON array of image URLs / data URLs
  status      String   @default("active") // active | sold | removed
  createdAt   DateTime @default(now())

  offers        Offer[]
  conversations Conversation[]
  orders        Order[]
  reports       Report[]
}

model Offer {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id])
  buyerId     String
  buyer       User     @relation(fields: [buyerId], references: [id])
  amountCents Int
  status      String   @default("pending") // pending | accepted | declined | countered
  fromSeller  Boolean  @default(false) // true when this row is a seller counter-offer
  createdAt   DateTime @default(now())
}

model Conversation {
  id                String    @id @default(cuid())
  listingId         String
  listing           Listing   @relation(fields: [listingId], references: [id])
  buyerId           String
  buyer             User      @relation("BuyerConversations", fields: [buyerId], references: [id])
  sellerId          String
  seller            User      @relation("SellerConversations", fields: [sellerId], references: [id])
  buyerLastReadAt   DateTime?
  sellerLastReadAt  DateTime?
  createdAt         DateTime  @default(now())

  messages Message[]

  @@unique([listingId, buyerId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String
  createdAt      DateTime     @default(now())
}

model Order {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id])
  buyerId     String
  buyer       User     @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId    String
  seller      User     @relation("SellerOrders", fields: [sellerId], references: [id])
  amountCents Int
  // paid_escrow | courier_assigned | picked_up | in_transit | delivered | confirmed | refunded | disputed
  status      String   @default("paid_escrow")
  paymentRef  String? // mock payment reference; a real processor's intent id would live here
  courierId   String?
  courier     Courier? @relation(fields: [courierId], references: [id])
  createdAt   DateTime @default(now())

  deliveryEvents DeliveryEvent[]
  walletTxns     WalletTxn[]
  reviews        Review[]
}

model Courier {
  id   String @id @default(cuid())
  name String

  orders         Order[]
  deliveryEvents DeliveryEvent[]
}

model DeliveryEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  courierId String
  courier   Courier  @relation(fields: [courierId], references: [id])
  status    String // courier_assigned | picked_up | in_transit | delivered
  timestamp DateTime @default(now())
}

model WalletTxn {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String // credit | debit | withdrawal
  amountCents Int
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])
  status      String // held | released | completed | pending
  createdAt   DateTime @default(now())
}

model Review {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  fromUserId String
  fromUser   User     @relation("ReviewsGiven", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation("ReviewsReceived", fields: [toUserId], references: [id])
  rating     Int
  comment    String
  createdAt  DateTime @default(now())

  @@unique([orderId, fromUserId])
}

model Report {
  id           String   @id @default(cuid())
  reporterId   String
  reporter     User     @relation("ReportsMade", fields: [reporterId], references: [id])
  targetUserId String?
  targetUser   User?    @relation("ReportsAgainst", fields: [targetUserId], references: [id])
  listingId    String?
  listing      Listing? @relation(fields: [listingId], references: [id])
  reason       String
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("BlocksMade", fields: [blockerId], references: [id])
  blockedId String
  blocked   User     @relation("BlocksAgainst", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}
